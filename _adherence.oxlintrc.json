{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/fact-sheet/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Inter Display|Playfair Display))/i]",
        "message": "Font not provided by the design system. Available: Inter, Inter Display, Playfair Display."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent-color",
      "--accent-text-color",
      "--bio-title-color",
      "--font-body",
      "--font-display",
      "--font-quote",
      "--gutter",
      "--lapp-black",
      "--lapp-ink-faint",
      "--lapp-ink-muted",
      "--lapp-paper",
      "--lapp-paper-soft",
      "--lapp-rule",
      "--leading-body",
      "--leading-display",
      "--leading-quote",
      "--leading-tight",
      "--page-h",
      "--page-margin",
      "--page-margin-tight",
      "--page-w",
      "--runaround",
      "--t-body",
      "--t-body-lg",
      "--t-caption",
      "--t-display-lg",
      "--t-display-md",
      "--t-display-sm",
      "--t-display-xl",
      "--t-micro",
      "--t-quote",
      "--tracking-body",
      "--tracking-body-loose",
      "--tracking-display",
      "--tracking-uppercase",
      "--w-bold",
      "--w-light",
      "--w-medium",
      "--w-regular",
      "--w-semi"
    ],
    "tokenKinds": {
      "--lapp-black": "color",
      "--lapp-paper": "color",
      "--lapp-paper-soft": "color",
      "--lapp-rule": "color",
      "--lapp-ink-muted": "color",
      "--lapp-ink-faint": "color",
      "--accent-color": "color",
      "--accent-text-color": "font",
      "--bio-title-color": "color",
      "--page-w": "other",
      "--page-h": "other",
      "--page-margin": "spacing",
      "--page-margin-tight": "spacing",
      "--gutter": "other",
      "--runaround": "spacing",
      "--t-display-xl": "other",
      "--t-display-lg": "other",
      "--t-display-md": "other",
      "--t-display-sm": "other",
      "--t-quote": "other",
      "--t-body-lg": "other",
      "--t-body": "other",
      "--t-caption": "other",
      "--t-micro": "other",
      "--tracking-display": "font",
      "--tracking-uppercase": "font",
      "--tracking-body": "font",
      "--tracking-body-loose": "font",
      "--leading-display": "font",
      "--leading-quote": "font",
      "--leading-body": "font",
      "--leading-tight": "font",
      "--w-light": "other",
      "--w-regular": "other",
      "--w-medium": "other",
      "--w-semi": "other",
      "--w-bold": "other",
      "--font-display": "font",
      "--font-body": "font",
      "--font-quote": "font"
    },
    "fontFamilies": [
      "Inter",
      "Inter Display",
      "Playfair Display"
    ]
  }
}